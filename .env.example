# aimail — DIDComm mediator & mailbox
# Copy to .env and adjust.

# --- Server ---
# HTTP port for REST shim + DIDComm inbound (default 3080).
AIMAIL_PORT=3080
# Public base URL advertised in the mediator's DID document serviceEndpoint.
# Must be reachable by other agents (e.g. http://aimail:3080 in docker, https://aimail.example for prod).
AIMAIL_PUBLIC_URL=http://localhost:3080

# Enable WebSocket push transport for online agents (default true).
AIMAIL_WS_ENABLED=true

# --- DID ---
# DID method the mediator itself uses. 'key' is self-contained (no hosting).
# 'web' requires AIMAIL_PUBLIC_URL to serve /.well-known/did.json (Phase 2).
AIMAIL_DID_METHOD=key

# --- Storage ---
# Postgres connection (shared with ../market by default).
PGHOST=localhost
PGPORT=5432
PGUSER=marketplace
PGPASSWORD=marketplace
PGDATABASE=marketplace
# Database schema for aimail tables (default public).
AIMAIL_PG_SCHEMA=public

# --- At-rest encryption of mediator secrets ---
# Passphrase used to derive the AES-256-GCM key for the mediator's own
# DID/key material persisted in Postgres. Leave empty in dev to use a
# fixed throwaway key; MUST be set in production.
AIMAIL_KEY_PASSPHRASE=

# --- Mediator policy ---
# Auto-grant all incoming mediate-request messages (default true for an
# open mediator). Set false to require an allow-list (Phase 2).
AIMAIL_AUTO_GRANT_MEDIATION=true
